      "alternatives": ["terser", "esbuild"],
      "recommended": "esbuild",
      "reason": "grunt-contrib-uglify is deprecated",
      "migration_guide": "https://esbuild.github.io/"
    },
    "uglify-js": {
      "alternatives": ["terser", "esbuild"],
      "recommended": "terser",
      "reason": "uglify-js is no longer maintained",
      "migration_guide": "https://terser.org/"
    },
